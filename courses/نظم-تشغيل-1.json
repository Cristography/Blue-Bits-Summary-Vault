      { "type": "code", "language": "c", "code": "// FCFS Scheduling\nvoid fcfs_schedule(processes[], int n) {\n    int time = 0;\n    for (int i = 0; i < n; i++) {\n        processes[i].start = time;\n        time += processes[i].burst;\n        processes[i].completion = time;\n        processes[i].turnaround = time - processes[i].arrival;\n        processes[i].Waiting = processes[i].turnaround - processes[i].burst;\n    }\n}", "caption": "FCFS Implementation" },
