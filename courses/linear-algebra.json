{
  "course": { "id": "linear-algebra", "title_ar": "الجبر الخطي", "title_en": "Linear Algebra" },
  "components": [
    { "type": "card", "title": "📐 المفاهيم الأساسية", "icon": "📐", "children": [
      { "type": "definition", "term": "المصفوفة (Matrix)", "term_en": "Matrix", "description": "جدول أرقام مرتب في صفوف وأعمدة", "formula": "$A_{m \\times n}$" },
      { "type": "definition", "term": "المتجه (Vector)", "term_en": "Vector", "description": "مصفوفة من صف واحد أو عمود واحد", "formula": "$v = \\begin{pmatrix} x \\\\ y \\end{pmatrix}$" },
      { "type": "definition", "term": "رتبة المصفوفة (Rank)", "term_en": "Rank", "description": "عدد الأسطر المستقلة خطياً" },
      { "type": "definition", "term": "المحدد (Determinant)", "term_en": "Determinant", "description": "قيمة محددة من المصفوفة المربعة", "formula": "$\\det(A)$ or $|A|$" },
      { "type": "definition", "term": "المصفوفة المتماثلة", "term_en": "Symmetric Matrix", "description": "$A = A^T$", "formula": "$a_{ij} = a_{ji}$" }
    ]},
    { "type": "card", "title": "➕ العمليات على المصفوفات", "icon": "➕", "children": [
      { "type": "equation", "formula": "$C_{ij} = A_{ij} + B_{ij}$", "display": true, "label": "الجمع" },
      { "type": "equation", "formula": "$C_{ij} = \\sum_k A_{ik} B_{kj}$", "display": true, "label": "الضرب" },
      { "type": "equation", "formula": "$(AB)^T = B^T A^T$", "display": true, "label": "نقل المصفوفة" },
      { "type": "equation", "formula": "$(AB)^{-1} = B^{-1} A^{-1}$", "display": true, "label": "معكوس الضرب" },
      { "type": "example", "given": "$A = \\begin{pmatrix} 1 & 2 \\\\ 3 & 4 \\end{pmatrix}$, $B = \\begin{pmatrix} 2 & 0 \\\\ 1 & 2 \\end{pmatrix}$", "solution": "$A + B = \\begin{pmatrix} 3 & 2 \\\\ 4 & 6 \\end{pmatrix}$\n$AB = \\begin{pmatrix} 4 & 4 \\\\ 10 & 8 \\end{pmatrix}$", "result": "$A+B = \\begin{pmatrix} 3 & 2 \\\\ 4 & 6 \\end{pmatrix}$" }
    ]},
    { "type": "card", "title": "🧮 المحددات", "icon": "🧮", "children": [
      { "type": "equation", "formula": "$\\det\\begin{pmatrix} a & b \\\\ c & d \\end{pmatrix} = ad - bc$", "display": true, "label": "محدد 2×2" },
      { "type": "equation", "formula": "$\\det(A^T) = \\det(A)$", "display": true, "label": "خاصية 1" },
      { "type": "equation", "formula": "$\\det(AB) = \\det(A) \\cdot \\det(B)$", "display": true, "label": "خاصية 2" },
      { "type": "equation", "formula": "$\\det(A^{-1}) = \\frac{1}{\\det(A)}$", "display": true, "label": "خاصية 3" },
      { "type": "example", "given": "$A = \\begin{pmatrix} 3 & 1 & 2 \\\\ 2 & 1 & 1 \\\ 1 & 2 & 1 \\end{pmatrix}$", "solution": "$\\det = 3(1-2) - 1(2-1) + 2(4-1)$\n$= 3(-1) - 1(1) + 2(3)$\n$= -3 -1 + 6 = 2$", "result": "$\\det(A) = 2$" }
    ]},
    { "type": "card", "title": "📊 أنواع المصفوفات", "icon": "📊", "children": [
      { "type": "table", "headers": ["النوع", "الشرط", "مثال"], "rows": [
        ["مصفوفة الوحدة", "$I_n$", "مصفوفة m×n أصفار ما عدا diagonals = 1"],
        ["مصفوفة صفرية", "$0_{m×n}$", "كل العناصر = 0"],
        ["مصفوفة قطرية", "$D$", "$d_{ij} = 0$ for $i \\neq j$"],
        ["مصفوفة مثلثة supérieure", "$U$", "$u_{ij} = 0$ for $i > j$"],
        ["مصفوفة مثلثة inférieure", "$L$", "$l_{ij} = 0$ for $i < j$"]
      ], "caption": "أنواع المصفوفات الخاصة" }
    ]},
    { "type": "card", "title": "📈 المعكوس وحل المعادلات", "icon": "📈", "children": [
      { "type": "definition", "term": "المعكوس", "term_en": "Inverse", "description": "$A^{-1}$ بحيث $AA^{-1} = I$" },
      { "type": "equation", "formula": "$A^{-1} = \\frac{1}{\\det(A)} \\cdot \\text{adj}(A)$", "display": true, "label": "صيغة إيجاد المعكوس" },
      { "type": "example", "given": "$A = \\begin{pmatrix} 4 & 7 \\\\ 2 & 6 \\end{pmatrix}$", "solution": "$\\det = 24 - 14 = 10$\n$\\text{adj}(A) = \\begin{pmatrix} 6 & -7 \\\\ -2 & 4 \\end{pmatrix}$\n$A^{-1} = \\frac{1}{10} \\begin{pmatrix} 6 & -7 \\\ -2 & 4 \\end{pmatrix}$", "result": "$A^{-1} = \\begin{pmatrix} 0.6 & -0.7 \\\ -0.2 & 0.4 \\end{pmatrix}$" }
    ]},
    { "type": "card", "title": "🧮 قاعدة كرامر", "icon": "🧮", "children": [
      { "type": "theorem", "name": "قاعدة كرامر", "name_en": "Cramer's Rule", "statement": "حل أنظمة المعادلات الخطية", "formula": "$x_i = \\frac{\\det(A_i)}{\\det(A)}$" },
      { "type": "example", "given": "$2x + y = 5$\n$x - y = 1$", "solution": "$A = \\begin{pmatrix} 2 & 1 \\\\ 1 & -1 \\end{pmatrix}$, $B = \\begin{pmatrix} 5 \\\\ 1 \\end{pmatrix}$\n$\\det(A) = -2 - 1 = -3$\n$x = \\frac{\\det\\begin{pmatrix} 5 & 1 \\\ 1 & -1 \\end{pmatrix}}{-3} = \\frac{-6}{-3} = 2$\n$y = \\frac{\\det\\begin{pmatrix} 2 & 5 \\\\ 1 & 1 \\end{pmatrix}}{-3} = \\frac{-3}{-3} = 1$", "result": "$(x, y) = (2, 1)$" }
    ]},
    { "type": "card", "title": "📊 القيم الذاتية والمتجهات الذاتية", "icon": "📊", "children": [
      { "type": "definition", "term": "القيمة الذاتية", "term_en": "Eigenvalue", "description": "$Av = \\lambda v$", "formula": "$\\lambda$" },
      { "type": "definition", "term": "المتجه الذاتي", "term_en": "Eigenvector", "description": "المتجه الذي لا يتغير الاتجاه", "formula": "$v$" },
      { "type": "equation", "formula": "$\\det(A - \\lambda I) = 0$", "display": true, "label": "معادلة القيم الذاتية" },
      { "type": "example", "given": "$A = \\begin{pmatrix} 2 & 1\\\ 1 & 2 \\end{pmatrix}$", "solution": "$\\det\\begin{pmatrix} 2-\\lambda & 1\\\ 1 & 2-\lambda \\end{pmatrix} = (2-\\lambda)^2 - 1 = 0$\n$(2-\lambda)(2+\lambda) - 1 = 0$\n$4 - \lambda^2 - 1 = 0$ → $\lambda^2 = 3$\n$\lambda_1 = \\sqrt{3}, \\lambda_2 = -\\sqrt{3}$", "result": "$\lambda_1 = 1.732, \\lambda_2 = -1.732$" }
    ]},
    { "type": "card", "title": "⚠️ الأخطاء الشائعة", "icon": "⚠️", "children": [
      { "type": "warning", "variant": "warning", "title": "الأبعاد", "text": "يجب توافق أبعاد المصفوفات للجمع والضرب!" },
      { "type": "warning", "variant": "warning", "title": "commivité", "text": "$AB \\neq BA$ بشكل عام!" },
      { "type": "warning", "variant": "tip", "title": "معرفة المعكوس", "text": "$\\det(A) \\neq 0$ للمعكوس" }
    ]}
  ]
}