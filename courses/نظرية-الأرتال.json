      { "type": "definition", "term": "Type 1 - Context-Sensitive", "term_en": "CS Languages", "description": "LBA يقبلها" },
      { "type": "definition", "term": "Type 0 - Recursively Enumerable", "term_en": "RE Languages", "description": "Turing يقبلها" },
      { "type": "table", "headers": ["النوع", "ال machines", "الـ grammar", "Closed under"], "rows": [
        ["Type 3", "DFA/NFA", "Regular", "Union, Concatenion, Star"],
