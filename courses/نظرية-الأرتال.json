        ["Type 1", "LBA", "CS", "Intersection, Union"],
        ["Type 0", "TM", "Unrestricted", "Union, Concatenion"]
      ], "caption": "هرم تشومسكي" }
    ]},
    { "type": "card", "title": "📊 Pushdown Automata", "icon": "📊", "children": [
      { "type": "definition", "term": "PDA", "term_en": "Pushdown Automaton", "description": "DFA + Stack" },
      { "type": "table", "headers": ["النوع", "Description", "مثال"], "rows": [
        ["Deterministic", "حالة واحدة لكل مدخل", "a^n b^n"],
        ["Nondeterministic", "multiple transitions", "$ww^R$"],
        ["Stack push", "إضافة لل stack", "a → X"],
        ["Stack pop", "إزالة من stack", "X → ε"],
        ["Stack top", "العنصر العلوي", "top(X) = X"]
      ], "caption": "أنواع PDA" },
      { "type": "diagram", "chart": "flowchart", "code": "S0((Start)) -->|a| S1(push X)\nS1 -->|b| S2(pop X)\nS3((Accept)) <-- S2", "caption": " PDA لـ a^n b^n" }
    ]},
    { "type": "card", "title": "🧮 نظرية بومبينغ", "icon": "🧮", "children": [
      { "type": "theorem", "name": "Pumping Lemma (Regular)", "name_en": "Pumping Lemma", "statement": "لغة منتظمة، يوجد $n$ لكل $|w| \\geq n$", "formula": "$w = xyz, |y| > 0$" },
      { "type": "theorem", "name": "Pumping Lemma (CF)", "name_en": "Pumping Lemma for CFLs", "statement": "لغة حرة، يوجد $n$ لكل $|w| \\geq n$", "formula": "$w = uv^ixyz, i \\geq 0$" },
      { "type": "example", "given": "$L = \\{a^n b^n: n \\geq 0\\}$", "solution": "نفترض أنها منتظمة، إذن $p$Pump Lemma\nاخذ $w = a^p b^p$\n$w = xyz$ with $|y| > 0$\nالحالات:\ny في $a^*$ → $a^k a^p b^p$ لا في $L$y في $b^*$ → $a^p b^k b^p$ لا في $L$\ny في $a^* b^*$ → $a^{p+k} b^p$ أو $a^p b^{p+k}$ لا في $L$\nكل الحالات تفشل!", "result": "$a^n b^n$ غير منتظمة!" }
    ]},
    { "type": "card", "title": "⚠️ الأخطاء الشائعة", "icon": "⚠️", "children": [
