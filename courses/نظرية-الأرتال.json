      { "type": "definition", "term": "DFA", "term_en": "Deterministic FA", "description": "حالة واحدة لكل مدخل", "formula": "$M = (Q, \\Sigma, \\delta, q_0, F)$" },
      { "type": "definition", "term": "NFA", "term_en": "Nondeterministic FA", "description": "متعددة حالات لكل مدخل" },
      { "type": "equation", "formula": "$DFA \\equiv NFA$", "display": true, "label": "التكافؤ" },
      { "type": "diagram", "chart": "flowchart", "code": "START(q0) --> a(q1)\nq1 --> a(q1)\nq1 -->|b| q2\nq2 -->|b| q3\nq3((Accept))", "caption": "مثال DFA يقبل ab*" }
    ]},
    { "type": "card", "title": "💻 التعبيرات النمطية_regex", "icon": "💻", "children": [
      { "type": "table", "headers": ["الرمز", "المعنى", "مثال"], "rows": [
        ["a", "الحرف a", "تقبل 'a' فقط"],
        ["a*", "صفر أو أكثر", "تقبل '', 'a', 'aaa'..."],
        ["a+", "واحد أو أكثر", "تقبل 'a', 'aa', 'aaa'..."],
        ["a|b", "a أو b", "تقبل 'a' أو 'b'"],
        [".", "أي حرف", "تقبل أي حرف"],
        ["^", "بداية السلسلة", "must start"],
        ["$", "نهاية السلسلة", "must end"],
        ["(abc)", "تجميع", "treat as unit"]
      ], "caption": "رموز Regex" },
      { "type": "example", "given": "^[a-zA-Z_][a-zA-Z0-9_]*$", "solution": "^ = start\n[a-zA-Z_] = حرف أو underscore\n[a-zA-Z0-9_]* = أي عدد من حرف/رقم/underscore\n$ = end", "result": "Valid C identifier" }
    ]},
    { "type": "card", "title": "🧮 اللغات النظامية", "icon": "🧮", "children": [
