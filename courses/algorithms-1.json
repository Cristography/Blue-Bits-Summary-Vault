      ], "caption": "مقارنة خوارزميات البحث" },
      { "type": "code", "language": "cpp", "code": "// Binary Search\nint binarySearch(int arr[], int l, int r, int x) {\n    while (l <= r) {\n        int mid = l + (r-l)/2;\n        if (arr[mid] == x) return mid;\n        if (arr[mid] < x) l = mid + 1;\n        else r = mid - 1;\n    }\n    return -1;\n}", "caption": "Binary Search" },
      { "type": "example", "given": "$arr = [2, 5, 8, 12, 16]$, نبحث عن $12$", "solution": "الخطوة 1: mid = 2 (8) < 12 → left\nالخطوة 2: mid = 4 (16) > 12 → right\nالخطوة 3: mid = 3 (12) == 12 ✓", "result": "فُوجد في index 3" }
    ]},
