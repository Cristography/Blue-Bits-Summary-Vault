      { "type": "code", "language": "cpp", "code": "// Bubble Sort\nvoid bubbleSort(int arr[], int n) {\n    for (int i = 0; i < n-1; i++)\n        for (int j = 0; j < n-i-1; j++)\n            if (arr[j] > arr[j+1])\n                swap(arr[j], arr[j+1]);\n}", "caption": "Bubble Sort" },
      { "type": "diagram", "chart": "flowchart", "code": "A[5, 3, 8, 1] --> B{5 > 3}\nB -->|yes| C[swap]\nC --> D[3, 5, 8, 1]\nD --> E{5 > 8}\nE -->|no| F[3, 5, 1, 8]", "caption": "مثال على Swap" }
    ]},
