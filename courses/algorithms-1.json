      { "type": "theorem", "name": "التجميعية (Associativity)", "statement": "$(A \\cup B) \\cup C = A \\cup (B \\cup C)$", "formula": "$(A \\cup B) \\cup C = A \\cup (B \\cup C)$" },
      { "type": "theorem", "name": "التوزيعية (Distributivity)", "statement": "$A \\cap (B \\cup C) = (A \\cap B) \\cup (A \\cap C)$", "formula": "$A \\cap (B \\cup C) = (A \\cap B) \\cup (A \\cap C)$" }
    ]},
