      { "type": "theorem", "name": "شرط المستوية", "name_en": "Planarity Condition", "statement": "مخطط بسيط مستوي", "formula": "$m \\leq 3n - 6$ (where $n \\geq 3, \\deg(v) \\geq 3$)" },
